{
  "name": "context-canvas",
  "version": "0.1.0",
  "description": "让 Canvas 成为 AI 上下文 — 支持云盘媒体节点 + 时间戳笔记 + AI 问答",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf main.js manifest.json styles.css",
    "deploy": "cp main.js manifest.json styles.css '/Users/abcamus/obsidian仓库/AI库/.obsidian/plugins/context-canvas/'"
  },
  "keywords": [
    "obsidian",
    "canvas",
    "plugin"
  ],
  "author": "sync-vault",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "builtin-modules": "3.3.0",
    "esbuild": "0.21.0",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.4.0",
    "globals": "^17.7.0",
    "obsidian": "1.13.1",
    "tslib": "2.6.2",
    "tsx": "^4.22.3",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.62.1"
  }
}
