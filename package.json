{
  "name": "cloudweave",
  "version": "0.1.1",
  "description": "Cloud-storage file nodes + AI analysis for Canvas.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf main.js manifest.json styles.css"
  },
  "keywords": [
    "obsidian",
    "canvas",
    "plugin",
    "cloud-storage",
    "aliyun",
    "baidu",
    "quark",
    "onedrive"
  ],
  "author": "Camus Qiu",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",

    "esbuild": "0.21.0",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.4.0",
    "globals": "^17.7.0",
    "obsidian": "1.13.1",
    "tslib": "2.6.2",
    "tsx": "^4.22.3",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.62.1"
  }
}
